# Environment variables template
# Do NOT commit the actual .env file to version control.
# Copy this file to .env and fill in the values.

# Firebase API Keys (optional if hardcoding in firebase_options.dart, but recommended to secure)
FIREBASE_API_KEY_ANDROID=AIzaSyYourAndroidKeyHere
FIREBASE_API_KEY_IOS=AIzaSyYourIOSKeyHere

# App Check / ReCAPTCHA (if Web is used)
RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here

# Third-party APIs
# Add any other third party API keys below
# MIXPANEL_TOKEN=
# SENTRY_DSN=
